KEYWARS_IMAGE=ghcr.io/theheadless/keywars
KEYWARS_VERSION=latest
KEYWARS_BIND_ADDRESS=0.0.0.0
KEYWARS_PORT=8080

KEYWARS_LDAP_URLS=ldaps://dc01.example.local:636;ldaps://dc02.example.local:636
KEYWARS_LDAP_BASE_DN=DC=example,DC=local
KEYWARS_LDAP_UPN_SUFFIX=example.local
KEYWARS_LDAP_NETBIOS_DOMAIN=EXAMPLE
KEYWARS_LDAP_CA_CERTIFICATE_PATH=

KEYWARS_INSTANCE_NAME=KeyWars
KEYWARS_TIME_ZONE=Europe/Berlin
KEYWARS_MAX_CHALLENGE_PARTICIPANTS=64
KEYWARS_MAX_LIVE_PARTICIPANTS=64
KEYWARS_MAX_LIVE_SPECTATORS=128
KEYWARS_MAX_LIVE_ROOMS=200
KEYWARS_LIVE_BROADCAST_HZ=10
KEYWARS_LIVE_RECONNECT_SECONDS=30
KEYWARS_BACKUP_ENABLED=true
KEYWARS_BACKUP_RETENTION_DAYS=14
