@page "/texte"
@model KeyWars.Pages.Texte.IndexModel
@{
    ViewData["Title"] = "Texte";
}

<section class="page-header text-library-header">
    <div>
        <span class="eyebrow">Textbibliothek</span>
        <h1>Texte</h1>
        <p class="lead">Wähle längere, sinnvolle Trainingsvorlagen oder pflege eigene Texte für realistische Tipp-Runden.</p>
        <div class="hero-stat-row" aria-label="Textbibliothek Status">
            <span><strong>@Model.Texts.Count</strong> sichtbar</span>
            <span><strong>Privat</strong> möglich</span>
            <span><strong>Rating</strong> nur geeignete Texte</span>
        </div>
    </div>
    <div class="page-actions">
        <a class="button" asp-page="/Texte/Neu">Neuer Text</a>
        <a class="button secondary" asp-page="/Texte/Sammlungen/Neu">Sammlung anlegen</a>
    </div>
</section>

@if (Model.Texts.Count > 0)
{
    <section class="mobile-training-priority card" aria-labelledby="mobile-training-priority-title">
        <div class="section-title-row">
            <div>
                <span class="eyebrow">Jetzt starten</span>
                <h2 id="mobile-training-priority-title">Sofort trainieren</h2>
            </div>
            <a class="button secondary compact-button" href="#text-filter">Suchen</a>
        </div>
        <div class="mobile-text-quick-grid">
            @foreach (var text in Model.Texts.Take(2))
            {
                <article class="mobile-text-quick-card">
                    <div>
                        <h3>@text.Title</h3>
                        <div class="metadata-row">
                            <span class="meta-badge">@text.CharacterCount Zeichen</span>
                            <span class="meta-badge">@(text.IsStandard ? "Standard" : DisplayNames.For(text.Visibility))</span>
                        </div>
                    </div>
                    <div class="card-actions">
                        <a class="button" asp-page="/Spielen/Text" asp-route-id="@text.Id">Trainieren</a>
                        <a class="button secondary" asp-page="/Texte/Details" asp-route-id="@text.Id">Ansehen</a>
                    </div>
                </article>
            }
        </div>
    </section>
}

<section id="text-filter" class="card filter-panel">
    <form method="get" class="filter-form">
        <label>
            Suche
            <input asp-for="Suche" />
        </label>
        <label>
            Sichtbarkeit
            <select asp-for="Sichtbarkeit">
                <option value="">Alle sichtbaren Texte</option>
                <option value="Private">Privat</option>
                <option value="Organization">Organisationsweit</option>
            </select>
        </label>
        <div class="form-actions">
            <button type="submit">Filtern</button>
        </div>
    </form>
</section>

<section class="grid text-library-grid">
    @if (Model.Texts.Count == 0)
    {
        <div class="empty-state featured-empty">
            <h3>Keine Texte gefunden</h3>
            <p>Setze den Filter zurück oder lege einen längeren Trainingsbaustein mit klarem Titel an.</p>
            <div class="card-actions">
                <a class="button" asp-page="/Texte/Neu">Text anlegen</a>
                <a class="button secondary" asp-page="/Texte/Index">Filter zurücksetzen</a>
            </div>
        </div>
    }
    @foreach (var text in Model.Texts)
    {
        <article class="card text-card">
            <div>
                <h2>@text.Title</h2>
                <div class="metadata-row">
                    <span class="meta-badge">@text.CharacterCount Zeichen</span>
                    <span class="meta-badge">@(text.IsStandard ? "Standard" : DisplayNames.For(text.Visibility))</span>
                </div>
            </div>
            <div class="card-actions">
                <a class="button secondary" asp-page="/Texte/Details" asp-route-id="@text.Id">Ansehen</a>
                <a class="button" asp-page="/Spielen/Text" asp-route-id="@text.Id">Trainieren</a>
            </div>
        </article>
    }
</section>

<section class="text-library-mobile-actions card" aria-labelledby="text-library-mobile-actions-title">
    <div>
        <span class="eyebrow">Verwaltung</span>
        <h2 id="text-library-mobile-actions-title">Eigene Texte pflegen</h2>
        <p>Lege längere Trainingsvorlagen oder Sammlungen an, wenn du gezielt mit eigenen Inhalten üben möchtest.</p>
    </div>
    <div class="card-actions">
        <a class="button" asp-page="/Texte/Neu">Neuer Text</a>
        <a class="button secondary" asp-page="/Texte/Sammlungen/Neu">Sammlung anlegen</a>
    </div>
</section>
