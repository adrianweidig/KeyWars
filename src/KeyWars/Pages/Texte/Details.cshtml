@page "/texte/{id:guid}"
@model KeyWars.Pages.Texte.DetailsModel
@{
    ViewData["Title"] = Model.Text.Title;
}

<section class="page-header">
    <div>
        <h1>@Model.Text.Title</h1>
        <p class="lead">@Model.Text.CharacterCount Zeichen · @(Model.Text.IsStandard ? "Standardtext" : Model.Text.Visibility)</p>
    </div>
    <div class="action-row">
        <a class="button" asp-page="/Spielen/Text" asp-route-id="@Model.Text.Id">Trainieren</a>
        <a class="button secondary" asp-page="/Herausforderungen/Neu" asp-route-textId="@Model.Text.Id">Herausfordern</a>
    </div>
</section>

<section class="card">
    <pre style="white-space: pre-wrap; font: inherit;">@Model.Text.Body</pre>
</section>
