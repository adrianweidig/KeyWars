@page "/arena/{id:guid}/rennen"
@model KeyWars.Pages.Arena.RaumModel
@{
    ViewData["Title"] = "Arena-Rennen";
}

<section class="page-header">
    <div>
        <h1>@Model.Snapshot.Title</h1>
        <p class="lead">Code @Model.Snapshot.Code · @DisplayNames.For(Model.Snapshot.Mode) · @Model.Snapshot.Participants.Count Personen</p>
    </div>
    <div class="action-row">
        <form method="post" asp-page-handler="Ready" data-arena-ready-form>
            <button type="submit" class="secondary">Bereit</button>
        </form>
        <form method="post" asp-page-handler="Start" data-arena-start-form>
            <button type="submit">Starten</button>
        </form>
    </div>
</section>

<div asp-validation-summary="ModelOnly"></div>

<section class="dashboard-grid" data-arena-room data-room-id="@Model.Snapshot.RoomId" data-current-profile-id="@Model.CurrentProfileId">
    <div class="card">
        <h2>Rennen</h2>
        <p class="muted" data-arena-state>@(Model.Snapshot.Started ? "Rennen läuft" : "Lobby")</p>
        <div class="typing-target" data-arena-target>@Model.Snapshot.TargetText</div>
        <div class="typing-timer" data-arena-timer>
            <strong>00:00.0</strong>
            <span>@(Model.Snapshot.Started ? "vergangen" : "Bereit")</span>
        </div>
        <form method="post" asp-page-handler="Finish" class="form-grid form-grid-spaced" data-arena-finish-form>
            <label>
                Eingabe
                <textarea asp-for="Input" class="typing-input" data-arena-input autocapitalize="off" autocomplete="off" spellcheck="false"></textarea>
            </label>
            <button type="submit" data-arena-finish>Zieleinlauf speichern</button>
        </form>
    </div>
    <aside class="card">
        <h2>Teilnehmende</h2>
        <table class="table">
            <thead><tr><th>Name</th><th>Status</th><th>Fortschritt</th><th>Platz</th></tr></thead>
            <tbody data-arena-participants>
            @foreach (var participant in Model.Snapshot.Participants)
            {
                <tr>
                    <td>@participant.DisplayName</td>
                    <td><span class="pill">@DisplayNames.For(participant.Status)</span></td>
                    <td>@participant.CorrectCharacters / @Model.Snapshot.TargetCharacterCount</td>
                    <td>@(participant.Placement?.ToString() ?? "-")</td>
                </tr>
            }
            </tbody>
        </table>
    </aside>
</section>
