@page "/arena"
@model KeyWars.Pages.Arena.IndexModel
@{
    ViewData["Title"] = "Arena";
}

<section class="page-header arena-lobby-hero">
    <div>
        <span class="eyebrow">Live-Wettbewerb</span>
        <h1>Live-Arena</h1>
        <p class="lead">Starte ein gemeinsames Rennen mit sichtbarem Textfortschritt, Fehlern und Zieleinlauf. Der Tippbereich bleibt zuerst, Raumverwaltung bleibt sekundär.</p>
        <div class="hero-stat-row" aria-label="Arena Status">
            <span><strong>@Model.Rooms.Count</strong> offene Lobbys</span>
            <span><strong>Textboard</strong> live</span>
            <span><strong>Rating</strong> nach Rennen</span>
        </div>
    </div>
    <div class="page-actions">
        <a class="button" asp-page="/Arena/Neu">Live-Rennen starten</a>
        <a class="button secondary" asp-page="/Arena/Beitreten">Code beitreten</a>
    </div>
</section>

<section class="arena-entry-grid">
    <article class="card arena-entry arena-entry-primary">
        <span class="badge">Sofort</span>
        <h2>Rennen anlegen</h2>
        <p class="muted">Wähle einen Text, teile den Code und starte nach dem Countdown. Ideal für kurze Wettkampf-Sessions.</p>
        <div class="card-actions">
            <a class="button" asp-page="/Arena/Neu">Live-Rennen starten</a>
        </div>
    </article>
    <article class="card arena-entry">
        <span class="badge">Code</span>
        <h2>Challenge annehmen</h2>
        <p class="muted">Füge den Raumcode ein und springe direkt in die Lobby deines Gegners.</p>
        <div class="card-actions">
            <a class="button secondary" asp-page="/Arena/Beitreten">Code beitreten</a>
        </div>
    </article>
    <article class="card arena-entry">
        <span class="badge">Offen</span>
        <h2>Offene Lobbys</h2>
        <p class="muted">Sieh nach, ob gerade jemand auf Mitspieler wartet, oder sammle vorher Tempo in einer Sofortrunde.</p>
        <div class="card-actions">
            <a class="button secondary" href="#offene-raeume">Räume ansehen</a>
        </div>
    </article>
</section>

<section id="offene-raeume" class="stack-spaced">
    <div class="section-title-row">
        <h2>Offene Räume</h2>
        <span class="muted">Live-Lobbys vor dem Start</span>
    </div>
    @if (Model.Rooms.Count == 0)
    {
        <div class="empty-state">
            <h3>Keine Lobby wartet gerade</h3>
            <p>Starte selbst ein kurzes Rennen oder nutze eine Sofortrunde, bis der nächste Gegner online ist.</p>
            <div class="card-actions">
                <a class="button" asp-page="/Arena/Neu">Live-Rennen starten</a>
                <a class="button secondary" asp-page="/Spielen/Index">Sofortrunde spielen</a>
            </div>
        </div>
    }
    else
    {
        <div class="grid">
        @foreach (var room in Model.Rooms)
        {
            var host = room.Participants.FirstOrDefault(item => item.ProfileId == room.CreatorProfileId)?.DisplayName ?? "Raumleitung";
            <article class="card room-card">
                <div class="section-title-row">
                    <h3>@room.Title</h3>
                    <span class="pill">@DisplayNames.For(room.Phase)</span>
                </div>
                <dl class="room-facts">
                    <div><dt>Host</dt><dd>@host</dd></div>
                    <div><dt>Modus</dt><dd>@DisplayNames.For(room.Mode)</dd></div>
                    <div><dt>Teilnehmer</dt><dd>@room.Participants.Count / @room.MaxParticipants</dd></div>
                    <div><dt>Format</dt><dd>Runde @room.CurrentRound von @room.RoundCount</dd></div>
                </dl>
                <div class="room-code-share">
                    <span class="room-code">Code <strong>@room.Code</strong></span>
                    <button type="button" class="secondary compact-button" data-copy-text="@room.Code" data-copy-success="Raumcode kopiert.">Code kopieren</button>
                    <button type="button" class="secondary compact-button" data-share-title="KeyWars-Raum @room.Code" data-share-text="KeyWars-Raumcode @room.Code" data-share-url="@Url.Page("/Arena/Beitreten")" data-share-fallback="@room.Code">Einladung teilen</button>
                    <span class="copy-status" data-copy-status aria-live="polite"></span>
                </div>
                <a class="button secondary" asp-page="/Arena/Raum" asp-route-id="@room.RoomId">Öffnen</a>
            </article>
        }
        </div>
    }
</section>
