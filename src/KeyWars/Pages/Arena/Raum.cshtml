@page "/arena/{id:guid}"
@model KeyWars.Pages.Arena.RaumModel
@{
    ViewData["Title"] = Model.Snapshot.Title;
    var currentParticipant = Model.Snapshot.Participants.FirstOrDefault(item => item.ProfileId == Model.CurrentProfileId);
    var isHost = Model.Snapshot.CreatorProfileId == Model.CurrentProfileId;
    var inLobby = Model.Snapshot.Phase == LiveRoomPhase.Lobby;
    var readyButtonText = currentParticipant?.Ready == true ? "Nicht bereit" : "Bereit";
    var rankedParticipants = Model.Snapshot.Participants
        .OrderBy(item => item.Placement ?? int.MaxValue)
        .ThenByDescending(item => item.CorrectCharacters)
        .ThenBy(item => item.DisplayName)
        .ToList();
    var displayMode = DisplayMode(rankedParticipants.Count);
    var visibleParticipants = VisibleParticipants(rankedParticipants, Model.CurrentProfileId, displayMode).ToList();
    var hiddenParticipants = Math.Max(0, rankedParticipants.Count - visibleParticipants.Count);
}

<section class="page-header">
    <div>
        <h1>@Model.Snapshot.Title</h1>
        <p class="lead">Code @Model.Snapshot.Code · @DisplayNames.For(Model.Snapshot.Mode) · Runde @Model.Snapshot.CurrentRound von @Model.Snapshot.RoundCount · @Model.Snapshot.Participants.Count @(Model.Snapshot.Participants.Count == 1 ? "Person" : "Personen")</p>
    </div>
    <div class="action-row">
        @if (inLobby)
        {
            <form method="post" asp-page-handler="Ready" data-arena-ready-form data-ready="@((currentParticipant?.Ready == true).ToString().ToLowerInvariant())">
                <button type="submit" class="secondary">@readyButtonText</button>
            </form>
        }
        @if (isHost && inLobby)
        {
            <form method="post" asp-page-handler="Start" data-arena-start-form>
                <button type="submit">Starten</button>
            </form>
        }
        <button type="button" class="secondary" data-arena-leave>Raum verlassen</button>
    </div>
</section>

<div asp-validation-summary="ModelOnly"></div>

<section class="dashboard-grid" data-arena-room data-room-id="@Model.Snapshot.RoomId" data-current-profile-id="@Model.CurrentProfileId" data-arena-display-mode="@displayMode" data-max-participants="@Model.Snapshot.MaxParticipants" data-show-live-wpm="@Bool(Model.ShowLiveWpm)" data-show-live-rank-changes="@Bool(Model.ShowLiveRankChanges)" data-sound-enabled="@Bool(Model.SoundEnabled)" data-sound-volume="@Model.SoundVolumePercent" data-reactions-enabled="@Bool(Model.ReactionsEnabled)" data-reduced-motion="@Bool(Model.ReducedMotion)">
    <div class="card">
        <h2>Rennen</h2>
        <p class="muted" data-arena-state>@DisplayNames.For(Model.Snapshot.Phase)</p>
        <div class="arena-hud" data-arena-hud>
            <div class="metric"><span>Rang</span><strong data-hud-rank>@CurrentRank(currentParticipant, rankedParticipants)</strong></div>
            @if (Model.ShowLiveWpm)
            {
                <div class="metric"><span>WPM</span><strong data-hud-wpm>@FormatNumber(currentParticipant?.Wpm)</strong></div>
            }
            <div class="metric"><span>Genauigkeit</span><strong data-hud-accuracy>@FormatNumber(currentParticipant?.Accuracy) %</strong></div>
            <div class="metric"><span>Fortschritt</span><strong data-hud-progress>@ProgressPercent(currentParticipant, Model.Snapshot.TargetCharacterCount).ToString("0", System.Globalization.CultureInfo.InvariantCulture) %</strong></div>
        </div>
        <div class="arena-scale-note">
            <strong data-arena-mode-label>@DisplayModeLabel(displayMode)</strong>
            <span data-arena-roster-summary>@RosterSummary(rankedParticipants.Count, visibleParticipants.Count, Model.Snapshot.MaxParticipants)</span>
            <span data-arena-spectator-summary>Zuschauerrolle vorbereitet</span>
            <span data-arena-connection-quality>Verbindung: wird aufgebaut</span>
        </div>
        @if (Model.ReactionsEnabled)
        {
            <div class="reaction-panel" data-arena-reactions aria-label="Positive Arena-Reaktionen senden">
                <button type="button" class="secondary" data-reaction-key="stark" aria-label="Reaktion Stark senden">Stark</button>
                <button type="button" class="secondary" data-reaction-key="knapp" aria-label="Reaktion Knapp senden">Knapp</button>
                <button type="button" class="secondary" data-reaction-key="sauber" aria-label="Reaktion Sauber senden">Sauber</button>
                <button type="button" class="secondary" data-reaction-key="revanche" aria-label="Reaktion Revanche senden">Revanche</button>
                <button type="button" class="secondary" data-reaction-key="respekt" aria-label="Reaktion Respekt senden">Respekt</button>
            </div>
            <div class="reaction-stream" data-arena-reaction-stream aria-live="polite" aria-atomic="false"></div>
        }
        <div class="race-track @displayMode" data-arena-track aria-label="Rennstrecke mit bestätigtem Fortschritt">
            <div class="race-milestones" aria-hidden="true">
                <span style="left:25%">25</span>
                <span style="left:50%">50</span>
                <span style="left:75%">75</span>
                <span style="left:100%">Ziel</span>
            </div>
            @foreach (var participant in visibleParticipants)
            {
                var progress = ProgressPercent(participant, Model.Snapshot.TargetCharacterCount);
                var isCurrent = participant.ProfileId == Model.CurrentProfileId;
                var isParticipantHost = participant.ProfileId == Model.Snapshot.CreatorProfileId;
                <div class="race-lane @(isCurrent ? "current" : "")" data-track-participant-id="@participant.ProfileId">
                    <div class="race-lane-meta">
                        <span class="race-token">@Initials(participant.DisplayName)</span>
                        <span>@participant.DisplayName</span>
                        @if (isParticipantHost)
                        {
                            <span class="badge">Host</span>
                        }
                        @if (participant.Ready)
                        {
                            <span class="badge">Bereit</span>
                        }
                    </div>
                    <div class="race-lane-bar" aria-label="@participant.DisplayName: @progress.ToString("0", System.Globalization.CultureInfo.InvariantCulture) Prozent">
                        <span class="race-position" style="transform:translateX(@progress.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)%);">
                            <span>@Initials(participant.DisplayName)</span>
                        </span>
                    </div>
                </div>
            }
            <p class="muted roster-window-note @(hiddenParticipants > 0 ? "" : "is-hidden")" data-arena-window-note>@HiddenParticipantsText(hiddenParticipants)</p>
        </div>
        <div class="typing-target" data-arena-target>
            @if (string.IsNullOrEmpty(Model.Snapshot.TargetText))
            {
                <span class="muted">Der Text wird zum Start freigegeben.</span>
            }
            else
            {
                @Model.Snapshot.TargetText
            }
        </div>
        <div class="typing-timer" data-arena-timer>
            <strong>00:00.0</strong>
            <span>@DisplayNames.For(Model.Snapshot.Phase)</span>
        </div>
        <div class="form-grid form-grid-spaced">
            <label>
                Eingabe
                <textarea asp-for="Input" class="typing-input" data-arena-input autocapitalize="off" autocomplete="off" spellcheck="false"></textarea>
            </label>
            <button type="button" class="secondary" data-arena-dnf>Runde aufgeben</button>
        </div>
        <div class="visually-hidden" aria-live="polite" data-arena-live-region></div>
    </div>
    <aside class="card">
        <h2>Teilnehmende</h2>
        <table class="table participant-list @displayMode">
            <thead><tr><th>Name</th><th>Status</th><th>Fortschritt</th><th>Platz</th></tr></thead>
            <tbody data-arena-participants>
            @foreach (var participant in visibleParticipants)
            {
                <tr data-participant-id="@participant.ProfileId">
                    <td>@participant.DisplayName</td>
                    <td><span class="pill">@DisplayNames.For(participant.Status)</span></td>
                    <td>@participant.CorrectCharacters / @Model.Snapshot.TargetCharacterCount</td>
                    <td>@(participant.Placement?.ToString() ?? "-")</td>
                </tr>
            }
            </tbody>
        </table>
        <p class="muted @(hiddenParticipants > 0 ? "" : "is-hidden")" data-arena-hidden-count>@HiddenParticipantsText(hiddenParticipants)</p>
        <div class="podium @(Model.Snapshot.Finished ? "" : "is-hidden")" data-arena-podium>
            <h2>Podium</h2>
            @foreach (var participant in rankedParticipants.Where(item => item.Status is ParticipantStatus.Finished or ParticipantStatus.Dnf).Take(3))
            {
                <div class="podium-row" data-podium-participant-id="@participant.ProfileId">
                    <strong>@(participant.Placement?.ToString() ?? "-"). @participant.DisplayName</strong>
                    <span>@FormatNumber(participant.Wpm) WPM · @FormatNumber(participant.Accuracy) %</span>
                </div>
            }
        </div>
    </aside>
</section>

@functions {
    private static string Initials(string value)
    {
        var parts = value.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 0)
        {
            return "KW";
        }

        return string.Concat(parts.Take(2).Select(part => part[0].ToString().ToUpperInvariant()));
    }

    private static double ProgressPercent(KeyWars.Services.LiveParticipantSnapshot? participant, int targetCharacters)
    {
        if (participant is null || targetCharacters <= 0)
        {
            return 0;
        }

        return Math.Clamp(participant.CorrectCharacters * 100d / targetCharacters, 0, 100);
    }

    private static string CurrentRank(KeyWars.Services.LiveParticipantSnapshot? participant, IReadOnlyList<KeyWars.Services.LiveParticipantSnapshot> ranked)
    {
        if (participant is null)
        {
            return "-";
        }

        var index = ranked.Select((item, rank) => new { item.ProfileId, Rank = rank + 1 }).FirstOrDefault(item => item.ProfileId == participant.ProfileId);
        return index is null ? "-" : index.Rank.ToString(System.Globalization.CultureInfo.GetCultureInfo("de-DE"));
    }

    private static string FormatNumber(double? value) =>
        value is null ? "-" : value.Value.ToString("0.0", System.Globalization.CultureInfo.GetCultureInfo("de-DE"));

    private static string Bool(bool value) => value.ToString().ToLowerInvariant();

    private static string DisplayMode(int participantCount) => participantCount switch
    {
        <= 8 => "detailed",
        <= 24 => "compact",
        _ => "focused"
    };

    private static string DisplayModeLabel(string mode) => mode switch
    {
        "detailed" => "Detailansicht",
        "compact" => "Kompakte Ansicht",
        "focused" => "Fokussierte Ansicht",
        _ => "Arena-Ansicht"
    };

    private static string RosterSummary(int totalParticipants, int visibleParticipants, int maxParticipants)
    {
        if (totalParticipants == visibleParticipants)
        {
            return $"{totalParticipants} aktive Teilnehmende von {maxParticipants} Plätzen";
        }

        return $"{visibleParticipants} von {totalParticipants} Teilnehmenden im Fokus, Kapazität {maxParticipants}";
    }

    private static string HiddenParticipantsText(int hiddenParticipants) =>
        hiddenParticipants <= 0
            ? string.Empty
            : $"{hiddenParticipants} weitere Teilnehmende sind über Top-Plätze, eigene Position und Nachbarn zusammengefasst.";

    private static IReadOnlyList<KeyWars.Services.LiveParticipantSnapshot> VisibleParticipants(
        IReadOnlyList<KeyWars.Services.LiveParticipantSnapshot> ranked,
        Guid currentProfileId,
        string mode)
    {
        if (mode != "focused")
        {
            return ranked;
        }

        var selected = new Dictionary<Guid, KeyWars.Services.LiveParticipantSnapshot>();
        foreach (var participant in ranked.Take(3))
        {
            selected[participant.ProfileId] = participant;
        }

        var currentIndex = ranked.ToList().FindIndex(item => item.ProfileId == currentProfileId);
        if (currentIndex >= 0)
        {
            foreach (var index in new[] { currentIndex - 1, currentIndex, currentIndex + 1 })
            {
                if (index >= 0 && index < ranked.Count)
                {
                    var participant = ranked[index];
                    selected[participant.ProfileId] = participant;
                }
            }
        }

        return ranked.Where(item => selected.ContainsKey(item.ProfileId)).ToList();
    }
}
