@page "/arena/neu"
@model KeyWars.Pages.Arena.NeuModel
@{
    ViewData["Title"] = "Live-Raum starten";
}

<section class="page-header">
    <div>
        <h1>Live-Raum starten</h1>
        <p class="lead">Erstelle ein klassisches Rennen für 2 bis @Model.MaxParticipantsLimit Personen.</p>
    </div>
</section>

<section class="card">
    <form method="post" class="form-grid" data-submit-guard data-submit-busy-text="Raum wird erstellt...">
        <div asp-validation-summary="ModelOnly"></div>
        <label>
            Titel
            <input asp-for="Input.Title" maxlength="160" placeholder="Zum Beispiel: Mittagspause Sprint" />
            <span asp-validation-for="Input.Title"></span>
        </label>
        <label>
            Text
            <select asp-for="Input.TrainingTextId">
                @foreach (var text in Model.Texts)
                {
                    <option value="@text.Id">@text.Title</option>
                }
            </select>
            <span asp-validation-for="Input.TrainingTextId"></span>
        </label>
        <label>
            Sichtbarkeit
            <select asp-for="Input.Visibility">
                <option value="Code">Nur mit Raumcode</option>
                <option value="InternalOpen">Intern offen</option>
            </select>
        </label>
        <label>
            Maximale Teilnehmer
            <input asp-for="Input.MaxParticipants" type="number" min="2" max="@Model.MaxParticipantsLimit" />
            <span asp-validation-for="Input.MaxParticipants"></span>
        </label>
        <div class="form-note">
            <strong>Klassisches Rennen</strong>
            <span>Eine Runde, alle starten gemeinsam nach dem Countdown.</span>
        </div>
        <input type="hidden" asp-for="Input.Mode" />
        <input type="hidden" asp-for="Input.RoundCount" />
        <button type="submit">Raum erstellen</button>
    </form>
</section>
