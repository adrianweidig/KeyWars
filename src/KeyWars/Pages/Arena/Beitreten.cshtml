@page "/arena/beitreten"
@model KeyWars.Pages.Arena.BeitretenModel
@{
    ViewData["Title"] = "Raum beitreten";
}

<section class="page-header">
    <div>
        <h1>Mit Raumcode beitreten</h1>
        <p class="lead">Gib den sechsstelligen Raumcode ein.</p>
    </div>
</section>

<section class="card">
    <form method="post" class="form-grid">
        <div asp-validation-summary="ModelOnly"></div>
        <label>
            Raumcode
            <input asp-for="Code" class="room-code-input" data-room-code-input maxlength="6" minlength="6" pattern="[A-HJ-NP-Z2-9a-hj-np-z]{6}" autocomplete="off" autocapitalize="characters" spellcheck="false" />
        </label>
        <button type="submit">Beitreten</button>
    </form>
</section>
