@page
@using System.Globalization
@using KeyWars.Domain
@model KeyWars.Pages.IndexModel
@{
    ViewData["Title"] = "Start";
    ViewData["BodyClass"] = "dashboard-page";
    var culture = CultureInfo.GetCultureInfo("de-DE");
    var topSprint = Model.DailySprintBoard.Entries.Take(5).ToList();
    var podium = topSprint.Take(3).ToList();
    var leaderboardRows = topSprint.Skip(3).ToList();
    var missions = Model.Missions.Take(3).ToList();
    var recentResults = Model.Insights.History.Take(4).ToList();
    var ownSprint = Model.DailySprintBoard.OwnEntry;
}

<h1 class="visually-hidden">KeyWars Start</h1>

<section class="dashboard-cockpit" aria-label="KeyWars Cockpit">
    <article class="panel instant-round-panel typing-session-card dashboard-quick-round" data-typing-app data-mode="Sprint60" data-seconds="60" data-words="120" data-timer-placement="before-target">
        <div class="section-header">
            <div>
                <h2>Sofortrunde</h2>
                <p>60 Sekunden Vollgas. Dein bestes Ergebnis zählt.</p>
            </div>
            <a class="mode-select-link" asp-page="/Spielen/Sprint">Sprint 60s</a>
        </div>

        <div class="typing-target dashboard-target" data-target></div>

        <label class="typing-input-wrap">
            <span class="visually-hidden">Eingabe</span>
            <textarea class="typing-input dashboard-input" data-input disabled placeholder="Tippe hier..." autocapitalize="off" autocomplete="off" spellcheck="false"></textarea>
        </label>

        <div class="dashboard-round-footer">
            <div class="round-stats-preview" aria-label="Aktuelle Werte">
                <span><small>WPM</small><strong>@Model.LastWpm</strong></span>
                <span><small>Genauigkeit</small><strong>@Model.LastAccuracy %</strong></span>
                <span><small>Zeichen</small><strong>@Model.Insights.Totals.CorrectCharacters.ToString("N0", culture)</strong></span>
                <span><small>Fehler</small><strong>@Model.Insights.Totals.IncorrectCharacters.ToString("N0", culture)</strong></span>
                <span><small>Konsistenz</small><strong>@(Model.Insights.Trends.FirstOrDefault()?.AverageConsistency.ToString("0", culture) ?? "-") %</strong></span>
            </div>
            <div class="form-actions typing-actions">
                <button type="button" data-start>Neue Runde</button>
            </div>
        </div>
        <div data-result></div>
    </article>

    <aside class="panel daily-board-panel" aria-label="Tages-Sprint Rangliste">
        <div class="section-header">
            <div>
                <h2>Tages-Sprint 60s</h2>
                <p>24h-Board. Nur der beste gültige Lauf zählt.</p>
            </div>
            <a class="mode-select-link" asp-page="/Ranglisten" asp-route-board="sprint" asp-route-period="day" asp-route-mode="sprint60">24h</a>
        </div>

        @if (podium.Count == 0)
        {
            <div class="empty-state compact-empty leaderboard-empty">
                <h3>Noch kein Tageswert</h3>
                <p>Setze den ersten 60s-Wert und starte das Board.</p>
                <div class="card-actions">
                    <a class="button compact-button" asp-page="/Spielen/Sprint">Sprint starten</a>
                </div>
            </div>
        }
        else
        {
            <div class="mini-podium" aria-label="Top 3 Tages-Sprint">
                @foreach (var entry in podium)
                {
                    <article class="mini-podium-player rank-@entry.Rank @(entry.IsCurrentUser ? "is-user" : "")">
                        <span class="podium-crown" aria-hidden="true">@(entry.Rank == 1 ? "♛" : entry.Rank.ToString(culture))</span>
                        <span class="user-avatar" aria-hidden="true">@entry.Initials</span>
                        <strong>@entry.DisplayName</strong>
                        <small>@entry.PrimaryValue WPM</small>
                    </article>
                }
            </div>
            <div class="leaderboard-list">
                @foreach (var entry in leaderboardRows)
                {
                    <div class="leaderboard-row @(entry.IsCurrentUser ? "is-user" : "")">
                        <span>#@entry.Rank.ToString("N0", culture)</span>
                        <span>@entry.DisplayName</span>
                        <strong>@entry.PrimaryValue WPM</strong>
                    </div>
                }
                @if (ownSprint is not null && topSprint.All(entry => entry.UserProfileId != ownSprint.UserProfileId))
                {
                    <div class="leaderboard-row is-user">
                        <span>#@ownSprint.Rank.ToString("N0", culture)</span>
                        <span>Deine Position</span>
                        <strong>@ownSprint.PrimaryValue WPM</strong>
                    </div>
                }
            </div>
        }

        <a class="button secondary full-width" asp-page="/Ranglisten" asp-route-board="sprint" asp-route-period="day" asp-route-mode="sprint60">Zum Wettbewerb</a>
    </aside>
</section>

<section class="dashboard-grid-two">
    <article class="panel quests-panel">
        <div class="section-header compact">
            <h2>Deine Quests</h2>
            <a asp-page="/Profil/Ziele">Alle Ziele ansehen</a>
        </div>
        <div class="quest-grid">
            @foreach (var mission in missions)
            {
                var percent = mission.TargetValue <= 0 ? 0 : Math.Min(100, mission.CurrentValue * 100d / mission.TargetValue);
                <div class="quest-card @(mission.Completed ? "completed" : "")">
                    <span class="quest-icon @QuestIconClass(mission.Title)" aria-hidden="true">@QuestIcon(mission.Title)</span>
                    <strong>@mission.Title</strong>
                    <p>@mission.Description</p>
                    <progress class="progress xp-progress small" value="@percent.ToString("0.#", CultureInfo.InvariantCulture)" max="100" aria-label="Fortschritt für @mission.Title">@percent.ToString("0.#", culture) %</progress>
                    <div class="quest-footer">
                        <span>@mission.CurrentValue.ToString("N0", culture) / @mission.TargetValue.ToString("N0", culture)</span>
                        <span class="xp-chip">+@mission.XpReward.ToString("N0", culture) XP</span>
                    </div>
                </div>
            }
        </div>
    </article>

    <aside class="panel recent-results-panel">
        <div class="section-header compact">
            <h2>Letzte Ergebnisse</h2>
            <a asp-page="/Profil/Index">Alle ansehen</a>
        </div>
        @if (recentResults.Count == 0)
        {
            <p class="muted">Nach deiner ersten Runde erscheinen hier WPM, Genauigkeit und Modus.</p>
        }
        else
        {
            <div class="result-list">
                @foreach (var item in recentResults)
                {
                    <div class="result-row">
                        <span class="result-icon @ModeIconClass(item.Mode)" aria-hidden="true">@ModeIcon(item.Mode)</span>
                        <span>
                            <strong>@DisplayNames.For(item.Mode)</strong>
                            <small>@item.CreatedAt.LocalDateTime.ToString("g", culture)</small>
                        </span>
                        <strong>@item.Wpm.ToString("0", culture) WPM</strong>
                        <span>@item.Accuracy.ToString("0", culture) %</span>
                    </div>
                }
            </div>
        }
    </aside>
</section>

<section class="panel quickstart-panel">
    <h2>Schnell starten</h2>
    <div class="quickstart-grid">
        <a class="quickstart-card" asp-page="/Spielen/Index"><span class="quickstart-icon">▶</span><strong>Sofortrunde</strong><small>Sprint 60 Sekunden</small><span aria-hidden="true">›</span></a>
        <a class="quickstart-card" asp-page="/Spielen/Woerter"><span class="quickstart-icon">▤</span><strong>Wörtertest</strong><small>alle Wortlängen</small><span aria-hidden="true">›</span></a>
        <a class="quickstart-card" asp-page="/Spielen/Fehlerfokus"><span class="quickstart-icon">⌁</span><strong>Fehlerfokus</strong><small>schwache Zeichen</small><span aria-hidden="true">›</span></a>
        <a class="quickstart-card" asp-page="/Arena/Index"><span class="quickstart-icon">♜</span><strong>Arena-Rennen</strong><small>Live gegen andere</small><span aria-hidden="true">›</span></a>
        <a class="quickstart-card" asp-page="/Texte/Index"><span class="quickstart-icon">▣</span><strong>Text wählen</strong><small>eigene oder öffentliche</small><span aria-hidden="true">›</span></a>
        <a class="quickstart-card" asp-page="/Herausforderungen/Neu"><span class="quickstart-icon">♛</span><strong>Herausforderung</strong><small>Gruppe fordern</small><span aria-hidden="true">›</span></a>
    </div>
</section>

@functions {
    private static string QuestIcon(string title)
    {
        if (title.Contains("Streak", StringComparison.OrdinalIgnoreCase) || title.Contains("Serie", StringComparison.OrdinalIgnoreCase))
        {
            return "♦";
        }

        if (title.Contains("Fehler", StringComparison.OrdinalIgnoreCase))
        {
            return "↯";
        }

        return "◎";
    }

    private static string QuestIconClass(string title)
    {
        if (title.Contains("Streak", StringComparison.OrdinalIgnoreCase) || title.Contains("Serie", StringComparison.OrdinalIgnoreCase))
        {
            return "is-fire";
        }

        return title.Contains("Fehler", StringComparison.OrdinalIgnoreCase) ? "is-bolt" : "is-target";
    }

    private static string ModeIcon(TrainingMode mode) => mode switch
    {
        TrainingMode.WeaknessFocus => "↯",
        TrainingMode.Words10 or TrainingMode.Words25 or TrainingMode.Words50 or TrainingMode.Words100 => "▤",
        TrainingMode.Text => "▣",
        _ => "▶"
    };

    private static string ModeIconClass(TrainingMode mode) => mode switch
    {
        TrainingMode.WeaknessFocus => "is-bolt",
        TrainingMode.Words10 or TrainingMode.Words25 or TrainingMode.Words50 or TrainingMode.Words100 => "is-words",
        TrainingMode.Text => "is-text",
        _ => "is-sprint"
    };
}
