@page
@using System.Globalization
@model KeyWars.Pages.IndexModel
@{
    ViewData["Title"] = "Start";
    var culture = CultureInfo.GetCultureInfo("de-DE");
    var recentActivity = Model.Insights.ActivityDays.TakeLast(30).ToList();
    var activityColumns = 15;
    var activityStep = 13;
    var chartWidth = activityColumns * activityStep;
    var chartHeight = Math.Max(1, (int)Math.Ceiling(recentActivity.Count / (double)activityColumns)) * activityStep;
}

<section class="page-header dashboard-hero">
    <div>
        <span class="eyebrow">Trainings-Cockpit</span>
        <h1>Hallo, @Model.Profile.DisplayName</h1>
        <p class="lead">@Model.Recommendation.Text</p>
    </div>
    <div class="page-actions hero-actions">
        <a class="button" asp-page="/Spielen/Index"><span>Sofort tippen</span><small>60 Sekunden Fokus</small></a>
        <a class="button secondary" asp-page="/Arena/Neu"><span>Live-Raum</span><small>Rennen starten</small></a>
        <a class="button secondary" asp-page="/Ranglisten"><span>Wettbewerb</span><small>Rang verbessern</small></a>
        <a class="button secondary" asp-page="/Texte/Neu"><span>Eigener Text</span><small>realistisch trainieren</small></a>
    </div>
</section>

<section class="dashboard-grid">
    <div class="card level-cockpit">
        <div class="level-cockpit-top">
            <div>
                <span class="eyebrow">Tagesfokus</span>
                <h2>Level @Model.Profile.Level.ToString("N0", culture)</h2>
            </div>
            <span class="level-emblem">L@(Model.Profile.Level.ToString("N0", culture))</span>
        </div>
        <div class="metric-row">
            <div class="metric"><span>Letzte WPM</span><strong>@Model.LastWpm</strong></div>
            <div class="metric"><span>Genauigkeit</span><strong>@Model.LastAccuracy %</strong></div>
            <div class="metric"><span>Serie</span><strong>@Model.Profile.CurrentStreakDays.ToString("N0", culture) Tage</strong></div>
            <div class="metric"><span>Arena</span><strong>@Model.Insights.Division · @Model.Profile.ArenaRating.ToString("N0", culture)</strong></div>
            <div class="metric"><span>XP</span><strong>@Model.Profile.ExperiencePoints.ToString("N0", culture)</strong></div>
            <div class="metric"><span>Nächste Belohnung</span><strong>@Model.LevelProgress.RemainingXp.ToString("N0", culture) XP</strong></div>
        </div>
        <progress class="progress xp-progress" value="@Model.LevelProgress.ProgressPercent.ToString("0.#", CultureInfo.InvariantCulture)" max="100" aria-label="Fortschritt bis zum nächsten Level">@Model.LevelProgress.ProgressPercent.ToString("0.#", culture) %</progress>
        <div class="section-title-row">
            <p class="muted">@Model.LevelProgress.ProgressXp.ToString("N0", culture) / @((Model.LevelProgress.NextLevelXp - Model.LevelProgress.LevelStartXp).ToString("N0", culture)) XP in diesem Level</p>
            <a class="button secondary" asp-page="/Spielen/Index" asp-route-mode="@Model.Recommendation.Mode">Empfehlung starten</a>
        </div>
    </div>

    <aside class="card">
        <h2>30-Tage-Übersicht</h2>
        @if (recentActivity.All(item => item.Intensity == 0))
        {
            <div class="empty-state compact-empty">
                <h3>Starte deine erste Serie</h3>
                <p>Eine kurze Runde reicht, damit hier dein Trainingsrhythmus sichtbar wird.</p>
                <div class="card-actions">
                    <a class="button compact-button" asp-page="/Spielen/Index">Runde starten</a>
                </div>
            </div>
        }
        else
        {
            <svg class="activity-chart" viewBox="0 0 @chartWidth @chartHeight" role="img" aria-labelledby="dashboardActivityTitle">
                <title id="dashboardActivityTitle">Training, Arena und Ziele der letzten 30 Tage</title>
                @for (var index = 0; index < recentActivity.Count; index++)
                {
                    var day = recentActivity[index];
                    var x = index % activityColumns * activityStep;
                    var y = index / activityColumns * activityStep;
                    <rect x="@x" y="@y" width="10" height="10" rx="2" class="@ActivityClass(day.Intensity)">
                        <title>@day.Date.ToString("d", culture): @day.TrainingAttempts Training, @day.ArenaRuns Arena, @day.CompletedGoals Ziele</title>
                    </rect>
                }
            </svg>
        }
        <p class="muted">@Model.Insights.Totals.CompletedAttempts.ToString("N0", culture) abgeschlossene Versuche · @Model.Insights.Totals.TypedCharacters.ToString("N0", culture) Zeichen</p>
    </aside>
</section>

<section class="grid stack-spaced">
    <article class="card quest-panel">
        <div class="section-title-row">
            <h2>Heute relevant</h2>
            <a class="button secondary compact-button" asp-page="/Profil/Ziele">Alle Ziele</a>
        </div>
        <div class="quest-grid">
        @foreach (var mission in Model.Missions)
        {
            var percent = mission.TargetValue <= 0 ? 0 : Math.Min(100, mission.CurrentValue * 100d / mission.TargetValue);
            <div class="quest-card @(mission.Completed ? "completed" : "")">
                <div class="quest-card-head">
                    <strong>@mission.Title</strong>
                    <span class="xp-chip">+@mission.XpReward.ToString("N0", culture) XP</span>
                </div>
                <progress class="progress xp-progress small" value="@percent.ToString("0.#", CultureInfo.InvariantCulture)" max="100" aria-label="Fortschritt für @mission.Title">@percent.ToString("0.#", culture) %</progress>
                <span>@mission.CurrentValue.ToString("N0", culture) / @mission.TargetValue.ToString("N0", culture)</span>
                <p class="muted">@mission.Description</p>
            </div>
        }
        </div>
    </article>

    <aside class="card event-feed">
        <h2>Letzte Rewards</h2>
        @if (Model.Insights.RecentEvents.Count == 0)
        {
            <p class="muted">XP, Level-Ups und Badges erscheinen hier nach den ersten gültigen Runden.</p>
        }
        else
        {
            @foreach (var item in Model.Insights.RecentEvents.Take(6))
            {
                <div class="event-feed-row rarity-@item.Rarity.ToString().ToLowerInvariant()">
                    <span class="event-glyph">@EventGlyph(item.Type)</span>
                    <div>
                        <strong>@item.Title</strong>
                        <span>@item.Description</span>
                    </div>
                    @if (item.XpDelta > 0)
                    {
                        <span class="xp-chip">+@item.XpDelta.ToString("N0", culture) XP</span>
                    }
                </div>
            }
        }
    </aside>
</section>

<section class="grid stack-spaced">
    <aside class="card">
        <h2>Offene Wettbewerbe</h2>
        @if (Model.Challenges.Count == 0)
        {
            <div class="empty-state compact-empty">
                <h3>Keine Challenge offen</h3>
                <p>Erstelle eine kurze Gruppenrunde und gib anderen ein konkretes Ziel.</p>
                <div class="card-actions">
                    <a class="button secondary compact-button" asp-page="/Herausforderungen/Neu">Gruppe herausfordern</a>
                </div>
            </div>
        }
        else
        {
            <div class="challenge-list">
            @foreach (var challenge in Model.Challenges.Take(6))
            {
                <a class="challenge-row" asp-page="/Herausforderungen/Details" asp-route-id="@challenge.Id">
                    <span>@challenge.Title</span>
                    <span class="pill">@DisplayNames.For(challenge.Status)</span>
                </a>
            }
            </div>
        }
    </aside>
</section>

@functions {
    private static string EventGlyph(KeyWars.Domain.GamificationEventType type) => type switch
    {
        KeyWars.Domain.GamificationEventType.LevelUp => "LV",
        KeyWars.Domain.GamificationEventType.MissionCompleted => "Q",
        KeyWars.Domain.GamificationEventType.AchievementUnlocked => "B",
        KeyWars.Domain.GamificationEventType.PersonalBest => "PB",
        KeyWars.Domain.GamificationEventType.ArenaResult => "AR",
        _ => "XP"
    };

    private static string ActivityClass(int intensity) => intensity switch
    {
        >= 6 => "activity-cell-4",
        >= 4 => "activity-cell-3",
        >= 2 => "activity-cell-2",
        >= 1 => "activity-cell-1",
        _ => "activity-cell-0"
    };
}
