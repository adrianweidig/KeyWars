<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KeyWars</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
    var isActive = (string prefix) => currentPage.StartsWith(prefix, StringComparison.OrdinalIgnoreCase);
    var displayName = User.Identity?.Name ?? "KeyWars";
    var samAccount = User.FindFirst("samAccountName")?.Value ?? "";
}
    <header>
        <nav class="topbar" aria-label="Hauptnavigation">
            <a class="brand" asp-page="/Index" aria-label="KeyWars Startseite">
                <span class="brand-mark" aria-hidden="true">KW</span>
                <span>KeyWars</span>
            </a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="nav-links">
                    <a class="@(isActive("/Spielen") ? "active" : "")" asp-page="/Spielen/Index">Spielen</a>
                    <a class="@(isActive("/Arena") ? "active" : "")" asp-page="/Arena/Index">Arena</a>
                    <a class="@(isActive("/Texte") ? "active" : "")" asp-page="/Texte/Index">Texte</a>
                    <a class="@(isActive("/Profil") ? "active" : "")" asp-page="/Profil/Index">Profil</a>
                </div>
                <div class="user-chip" title="@displayName">
                    <span class="user-avatar" aria-hidden="true">@Initials(displayName)</span>
                    <span class="user-label"><strong>@displayName</strong><small>@samAccount</small></span>
                </div>
                <form class="logout" asp-page="/Abmelden" method="post">
                    <button type="submit" title="Abmelden" aria-label="Abmelden">Abmelden</button>
                </form>
            }
        </nav>
    </header>
    <div class="shell">
        <main role="main">
            @RenderBody()
        </main>
    </div>
    <script src="~/vendor/signalr/signalr.min.js" asp-append-version="true"></script>
    <script type="module" src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@functions {
    private static string Initials(string value)
    {
        var parts = value.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 0)
        {
            return "KW";
        }

        return string.Concat(parts.Take(2).Select(part => part[0].ToString().ToUpperInvariant()));
    }
}
