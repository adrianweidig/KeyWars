@using KeyWars.Auth
@using KeyWars.Domain
@using KeyWars.Services
@inject CurrentUser CurrentUser
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KeyWars</title>
    <link rel="icon" href="~/img/favicon.svg" type="image/svg+xml" asp-append-version="true" />
    <link rel="apple-touch-icon" href="~/img/apple-touch-icon.png" asp-append-version="true" />
    <link rel="manifest" href="~/img/site.webmanifest" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
    var isActive = (string prefix) => currentPage.StartsWith(prefix, StringComparison.OrdinalIgnoreCase);
    var isStart = currentPage.Equals("/Index", StringComparison.OrdinalIgnoreCase);
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var forcePublicShell = ViewData["ForcePublicShell"] as bool? == true;
    var showAuthenticatedShell = isAuthenticated && !forcePublicShell;
    UserProfile? layoutProfile = null;
    LevelProgress? layoutProgress = null;
    if (showAuthenticatedShell)
    {
        layoutProfile = await CurrentUser.RequireProfileAsync(User, Context.RequestAborted);
        layoutProgress = MotivationService.GetLevelProgress(layoutProfile.ExperiencePoints);
    }

    var displayName = layoutProfile?.DisplayName ?? User.Identity?.Name ?? "KeyWars";
    var samAccount = layoutProfile?.SamAccountName ?? User.FindFirst("samAccountName")?.Value ?? "";
    var bodyClass = string.Join(
        " ",
        new[] { ViewData["BodyClass"] as string, showAuthenticatedShell ? "app-authenticated" : "app-public" }
            .Where(value => !string.IsNullOrWhiteSpace(value)));
}
<body class="@bodyClass">
    <div class="app-shell">
        @if (showAuthenticatedShell)
        {
            <header class="desktop-topbar" aria-label="App-Leiste">
                <a class="brand app-brand" asp-page="/Index" aria-label="KeyWars Startseite">
                    <span class="brand-mark" aria-hidden="true">KW</span>
                    <span>KeyWars</span>
                </a>
                <div class="app-tools">
                    <button type="button" class="icon-button" data-design-mode-toggle title="Designmodus" aria-label="Designmodus" aria-pressed="false">@UiIcons.Svg("spark")</button>
                    <a class="profile-menu" asp-page="/Profil/Index">
                        <span>Mein Profil</span>
                        @UiIcons.Svg("chevron")
                    </a>
                    <form class="logout" asp-page="/Abmelden" method="post">
                        <button type="submit" title="Abmelden" aria-label="Abmelden">@UiIcons.Svg("logout")</button>
                    </form>
                </div>
            </header>

            <aside class="desktop-sidebar" aria-label="Hauptnavigation">
                <a class="brand app-brand" asp-page="/Index" aria-label="KeyWars Startseite">
                    <span class="brand-mark" aria-hidden="true">KW</span>
                    <span>KeyWars</span>
                </a>
                <nav class="sidebar-nav">
                    <a class="@(isStart ? "active" : "")" asp-page="/Index">@UiIcons.Svg("home")<span>Start</span></a>
                    <a class="@(isActive("/Spielen") ? "active" : "")" asp-page="/Spielen/Index">@UiIcons.Svg("play")<span>Spielen</span></a>
                    <a class="@(isActive("/Ranglisten") ? "active" : "")" asp-page="/Ranglisten">@UiIcons.Svg("trophy")<span>Wettbewerb</span></a>
                    <a class="@(isActive("/Arena") ? "active" : "")" asp-page="/Arena/Index">@UiIcons.Svg("arena")<span>Arena</span></a>
                    <a class="@(isActive("/Herausforderungen") ? "active" : "")" asp-page="/Herausforderungen/Index">@UiIcons.Svg("challenge")<span>Herausforderungen</span></a>
                    <a class="@(isActive("/Texte") ? "active" : "")" asp-page="/Texte/Index">@UiIcons.Svg("texts")<span>Texte</span></a>
                    <a class="@(isActive("/Profil") ? "active" : "")" asp-page="/Profil/Index">@UiIcons.Svg("profile")<span>Profil</span></a>
                    <a class="@(currentPage.Equals("/Profil/Einstellungen", StringComparison.OrdinalIgnoreCase) ? "active" : "")" asp-page="/Profil/Einstellungen">@UiIcons.Svg("settings")<span>Einstellungen</span></a>
                </nav>
                <a class="sidebar-profile" asp-page="/Profil/Index" title="@displayName">
                    <span class="user-avatar" aria-hidden="true">@Initials(displayName)</span>
                    <span class="user-label">
                        <strong>@displayName</strong>
                        <small>Level @layoutProfile!.Level</small>
                    </span>
                    <span class="sidebar-profile-arrow" aria-hidden="true">›</span>
                    <progress class="sidebar-xp-progress" value="@((layoutProgress?.ProgressPercent ?? 0).ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))" max="100" aria-label="Profil-Fortschritt">@((layoutProgress?.ProgressPercent ?? 0).ToString("0.#")) %</progress>
                </a>
            </aside>

            <header class="mobile-topbar">
                <a class="brand app-brand" asp-page="/Index" aria-label="KeyWars Startseite">
                    <span>KeyWars</span>
                </a>
                <button type="button" class="mobile-menu-button" data-mobile-menu-toggle aria-label="Navigation anzeigen">@UiIcons.Svg("menu")</button>
            </header>

            <div class="mobile-menu-panel" data-mobile-menu>
                <div class="mobile-menu-head">
                    <span>Navigation</span>
                    <button type="button" class="mobile-menu-button" data-mobile-menu-toggle aria-label="Navigation schließen">@UiIcons.Svg("close")</button>
                </div>
                <nav class="sidebar-nav">
                    <a class="@(isStart ? "active" : "")" asp-page="/Index">@UiIcons.Svg("home")<span>Start</span></a>
                    <a class="@(isActive("/Spielen") ? "active" : "")" asp-page="/Spielen/Index">@UiIcons.Svg("play")<span>Spielen</span></a>
                    <a class="@(isActive("/Ranglisten") ? "active" : "")" asp-page="/Ranglisten">@UiIcons.Svg("trophy")<span>Wettbewerb</span></a>
                    <a class="@(isActive("/Arena") ? "active" : "")" asp-page="/Arena/Index">@UiIcons.Svg("arena")<span>Arena</span></a>
                    <a class="@(isActive("/Herausforderungen") ? "active" : "")" asp-page="/Herausforderungen/Index">@UiIcons.Svg("challenge")<span>Herausforderungen</span></a>
                    <a class="@(isActive("/Texte") ? "active" : "")" asp-page="/Texte/Index">@UiIcons.Svg("texts")<span>Texte</span></a>
                    <a class="@(isActive("/Profil") ? "active" : "")" asp-page="/Profil/Index">@UiIcons.Svg("profile")<span>Profil</span></a>
                </nav>
            </div>
            <button type="button" class="mobile-menu-scrim" data-mobile-menu-toggle aria-label="Navigation schließen"></button>
        }

        <div class="app-main">
            @if (showAuthenticatedShell && layoutProfile is not null && layoutProgress is not null)
            {
                var xpTotal = Math.Max(1, layoutProgress.NextLevelXp);
                <header class="status-cockpit" aria-label="Trainingsstatus">
                    <div class="status-chip streak-chip"><span class="status-icon is-streak" aria-hidden="true">@UiIcons.Svg("fire", "kw-icon")</span><strong>@layoutProfile.CurrentStreakDays</strong><span>Tage Streak</span></div>
                    <div class="status-chip level-chip"><span>Level</span><strong>@layoutProfile.Level</strong></div>
                    <progress class="xp-track" value="@layoutProgress.ProgressPercent.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)" max="100" aria-label="Level-Fortschritt">@layoutProgress.ProgressPercent.ToString("0.#") %</progress>
                    <div class="xp-value"><strong>@layoutProfile.ExperiencePoints.ToString("N0")</strong> / @xpTotal.ToString("N0") XP</div>
                    <div class="next-rank"><span>Nächster Rang</span><span class="rank-token">@UiIcons.Svg("award", "kw-icon")<strong>@(layoutProfile.Level + 1)</strong></span></div>
                    <div class="app-tools">
                        <button type="button" class="icon-button" data-design-mode-toggle title="Designmodus" aria-label="Designmodus" aria-pressed="false">@UiIcons.Svg("spark")</button>
                        <a class="profile-menu" asp-page="/Profil/Index">
                            <span>Mein Profil</span>
                            @UiIcons.Svg("chevron")
                        </a>
                        <form class="logout" asp-page="/Abmelden" method="post">
                            <button type="submit" title="Abmelden" aria-label="Abmelden">@UiIcons.Svg("logout")</button>
                        </form>
                    </div>
                </header>
            }

            <main class="shell" role="main">
                @RenderBody()
            </main>
        </div>

        @if (showAuthenticatedShell)
        {
            <nav class="mobile-bottom-nav" aria-label="Schnellnavigation">
                <a class="@(isStart ? "active" : "")" asp-page="/Index">@UiIcons.Svg("home")<span>Start</span></a>
                <a class="@(isActive("/Spielen") ? "active" : "")" asp-page="/Spielen/Index">@UiIcons.Svg("play")<span>Spielen</span></a>
                <a class="@(isActive("/Ranglisten") ? "active" : "")" asp-page="/Ranglisten">@UiIcons.Svg("trophy")<span>Wettbewerb</span></a>
                <a class="@(isActive("/Arena") ? "active" : "")" asp-page="/Arena/Index">@UiIcons.Svg("arena")<span>Arena</span></a>
                <a class="@(isActive("/Profil") ? "active" : "")" asp-page="/Profil/Index">@UiIcons.Svg("profile")<span>Profil</span></a>
            </nav>
        }
    </div>
    <script src="~/vendor/signalr/signalr.min.js" asp-append-version="true"></script>
    <script type="module" src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@functions {
    private static string Initials(string value)
    {
        var parts = value.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 0)
        {
            return "KW";
        }

        return string.Concat(parts.Take(2).Select(part => part[0].ToString().ToUpperInvariant()));
    }

}
