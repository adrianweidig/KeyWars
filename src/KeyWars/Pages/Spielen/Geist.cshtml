@page "/spielen/geist/{attemptId:guid}"
@model KeyWars.Pages.Spielen.GeistModel
@{
    ViewData["Title"] = "Geisterrennen";
}

<section class="page-header">
    <div>
        <h1>Geisterrennen</h1>
        <p class="lead">Du trittst gegen eine gespeicherte Leistung auf demselben Text an.</p>
    </div>
</section>

<section class="card" data-typing-app data-mode="Ghost" data-text-id="@Model.TextId" data-hide-start-when-prepared="true">
    <p class="muted">Geist: @Model.ReferenceWpm WPM · @Model.ReferenceAccuracy % Genauigkeit</p>
    <div class="typing-target" data-target></div>
    <label>
        Eingabe
        <textarea class="typing-input" data-input disabled autocapitalize="off" autocomplete="off" spellcheck="false"></textarea>
    </label>
    <button type="button" data-start>Starten</button>
    <div data-result></div>
</section>
