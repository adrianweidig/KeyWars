@page "/spielen/woerter"
@model KeyWars.Pages.Spielen.WoerterModel
@{
    ViewData["Title"] = "Wörter";
}

<section class="page-header">
    <div>
        <h1>Wörtertests</h1>
        <p class="lead">Klassische Tests mit fester Wortzahl und deutscher QWERTZ-freundlicher Wortliste.</p>
    </div>
</section>

<section class="grid">
@foreach (var item in Model.Modes)
{
    <article class="card" data-typing-app data-mode="@item.Mode" data-words="@item.Words">
        <h2>@item.Words Wörter</h2>
        <div class="typing-target" data-target></div>
        <label>
            Eingabe
            <textarea class="typing-input" data-input disabled autocapitalize="off" autocomplete="off" spellcheck="false"></textarea>
        </label>
        <button type="button" data-start>Starten</button>
        <div data-result></div>
    </article>
}
</section>
