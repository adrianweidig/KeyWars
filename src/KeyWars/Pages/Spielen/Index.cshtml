@page "/spielen"
@model KeyWars.Pages.Spielen.IndexModel
@{
    ViewData["Title"] = "Spielen";
    ViewData["BodyClass"] = "play-page";
}

<section class="play-command-grid" aria-label="Training starten">
    <article class="panel play-quickstart typing-session-card" data-typing-app data-mode="Sprint60" data-seconds="60" data-words="120" data-timer-placement="before-target">
        <div class="section-header">
            <div>
                <h1>Sofortrunde</h1>
                <p>Ein sauberer 60-Sekunden-Lauf mit großer Textbahn, direkter Eingabe und Reward-Moment.</p>
            </div>
            <a class="mode-select-link" asp-page="/Spielen/Sprint">Sprint 60</a>
        </div>

        <div class="typing-target play-target" data-target></div>
        <label class="typing-input-wrap">
            <span class="visually-hidden">Eingabe</span>
            <textarea class="typing-input play-input" data-input disabled placeholder="Tippe hier..." autocapitalize="off" autocomplete="off" spellcheck="false"></textarea>
        </label>
        <div class="form-actions typing-actions">
            <button type="button" data-start>Neue Runde</button>
        </div>
        <div data-result></div>
    </article>

    <aside class="panel play-mode-panel" aria-label="Trainingsmodi">
        <div class="section-header compact">
            <h2>Fokus wählen</h2>
            <span class="muted">@Model.Texts.Count Texte</span>
        </div>
        <div class="play-focus-list">
            <a class="play-mode-link is-primary" asp-page="/Spielen/Sprint">
                <span>Sprint</span>
                <strong>Tempo halten</strong>
                <small>15 bis 120 Sekunden</small>
            </a>
            <a class="play-mode-link" asp-page="/Spielen/Woerter">
                <span>Wörter</span>
                <strong>Rhythmus finden</strong>
                <small>10 bis 100 Wörter</small>
            </a>
            <a class="play-mode-link" asp-page="/Spielen/Fehlerfokus">
                <span>Fokus</span>
                <strong>Muster korrigieren</strong>
                <small>Schwächen gezielt trainieren</small>
            </a>
            <a class="play-mode-link" asp-page="/Ranglisten" asp-route-board="sprint" asp-route-period="day" asp-route-mode="sprint60">
                <span>Wettbewerb</span>
                <strong>Bestwert angreifen</strong>
                <small>24h Sprint 60s</small>
            </a>
        </div>
    </aside>
</section>

<section class="panel play-library" aria-labelledby="play-library-title">
    <div class="section-header compact">
        <div>
            <h2 id="play-library-title">Texttraining</h2>
            <p>Größere Texte für ruhige, realistische Tipp-Runden.</p>
        </div>
        <a class="button secondary compact-button" asp-page="/Texte/Index">Alle Texte</a>
    </div>

    <div class="play-text-grid">
        @foreach (var text in Model.Texts)
        {
            <article class="text-card play-text-card">
                <div>
                    <h3>@text.Title</h3>
                    <p>@Model.Preview(text)</p>
                    <div class="metadata-row">
                        <span class="meta-badge">@text.CharacterCount Zeichen</span>
                        <span class="meta-badge">@(text.IsStandard ? "Standardtext" : DisplayNames.For(text.Visibility))</span>
                    </div>
                </div>
                <div class="card-actions">
                    <a class="button" asp-page="/Spielen/Text" asp-route-id="@text.Id">Text trainieren</a>
                </div>
            </article>
        }
    </div>
</section>
