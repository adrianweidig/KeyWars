@page "/spielen/text/{id:guid}"
@model KeyWars.Pages.Spielen.TextModel
@{
    ViewData["Title"] = "Texttraining";
}

<section class="page-header">
    <div>
        <span class="eyebrow">Texttraining</span>
        <h1>@Model.Text.Title</h1>
        <p class="lead">Texttraining mit exakt diesem Text. Absätze werden als Enter-Stellen sichtbar markiert.</p>
    </div>
</section>

<section class="card typing-session-card" data-typing-app data-mode="Text" data-text-id="@Model.Text.Id" data-hide-start-when-prepared="true">
    <div class="typing-target" data-target></div>
    <label>
        Eingabe
        <textarea class="typing-input" data-input disabled autocapitalize="off" autocomplete="off" spellcheck="false"></textarea>
    </label>
    <div class="form-actions typing-actions">
        <button type="button" data-start>Starten</button>
    </div>
    <div data-result></div>
</section>
