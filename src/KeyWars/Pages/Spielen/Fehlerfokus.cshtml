@page "/spielen/fehlerfokus"
@model KeyWars.Pages.Spielen.FehlerfokusModel
@{
    ViewData["Title"] = "Fehlerfokus";
}

<section class="page-header">
    <div>
        <span class="eyebrow">Präzision</span>
        <h1>Fehlerfokus</h1>
        <p class="lead">Die Übung wählt lokal Muster aus deinen bisherigen Beobachtungen. Ohne ausreichende Daten nutzt KeyWars deutsche Grundwörter.</p>
    </div>
</section>

<section class="card typing-session-card" data-typing-app data-mode="WeaknessFocus" data-words="80" data-hide-start-when-prepared="true">
    <div class="typing-target" data-target></div>
    <label>
        Eingabe
        <textarea class="typing-input" data-input disabled autocapitalize="off" autocomplete="off" spellcheck="false"></textarea>
    </label>
    <div class="form-actions typing-actions">
        <button type="button" data-start>Starten</button>
    </div>
    <div data-result></div>
</section>
