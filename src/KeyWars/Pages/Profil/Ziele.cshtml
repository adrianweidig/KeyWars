@page "/profil/ziele"
@using System.Globalization
@model KeyWars.Pages.Profil.ZieleModel
@{
    ViewData["Title"] = "Ziele";
    var culture = CultureInfo.GetCultureInfo("de-DE");
}

<section class="page-header">
    <div>
        <span class="eyebrow">Quests</span>
        <h1>Ziele</h1>
        <p class="lead">Tagesmissionen und Wochenziele stärken kurze, wiederholbare Trainingsschleifen.</p>
    </div>
    <div class="page-actions">
        <a class="button" asp-page="/Spielen/Index">Training starten</a>
        <a class="button secondary" asp-page="/Profil/Erfolge">Erfolge ansehen</a>
    </div>
</section>

<section class="quest-grid">
@foreach (var mission in Model.Missions)
{
    var percent = mission.TargetValue <= 0 ? 0 : Math.Min(100, mission.CurrentValue * 100d / mission.TargetValue);
    var visual = MotivationVisuals.ForMissionKey(mission.Key);
    <article class="card quest-card accent-@visual.Accent @(mission.Completed ? "completed" : "")">
        <div class="quest-card-head">
            <span class="quest-icon is-@visual.Accent" aria-hidden="true">@UiIcons.Svg(visual.VisualKey, "kw-icon")</span>
            <h2>@mission.Title</h2>
            <span class="xp-chip">+@mission.XpReward.ToString("N0", culture) XP</span>
        </div>
        <p>@mission.Description</p>
        <progress class="progress xp-progress" value="@percent.ToString("0.#", CultureInfo.InvariantCulture)" max="100" aria-label="Fortschritt für @mission.Title">@percent.ToString("0.#", culture) %</progress>
        <p class="muted">@mission.CurrentValue.ToString("N0", culture) / @mission.TargetValue.ToString("N0", culture) · @(mission.Completed ? "abgeschlossen" : percent >= 75 ? "fast geschafft" : "offen")</p>
    </article>
}
</section>
