@page "/profil/einstellungen"
@model KeyWars.Pages.Profil.EinstellungenModel
@{
    ViewData["Title"] = "Einstellungen";
}

<section class="page-header">
    <div>
        <h1>Einstellungen</h1>
        <p class="lead">Deine Identität kommt aus AD/LDAP. KeyWars speichert hier nur deine Vorlieben für Training, Arena und Sichtbarkeit.</p>
    </div>
</section>

<section class="card">
    @if (!string.IsNullOrWhiteSpace(Model.SavedMessage))
    {
        <div class="alert success" role="status">@Model.SavedMessage</div>
    }
    <div class="settings-layout">
        <section class="settings-identity" aria-labelledby="settings-identity-title">
            <h2 id="settings-identity-title">Identität aus AD/LDAP</h2>
            <p class="muted">Diese Angaben werden beim Anmelden aus dem Verzeichnis übernommen und bleiben in KeyWars unveränderlich.</p>
            <dl class="identity-list">
                <div>
                    <dt>Name</dt>
                    <dd>@Model.Identity.DisplayName</dd>
                </div>
                <div>
                    <dt>Konto</dt>
                    <dd>@Model.Identity.SamAccountName</dd>
                </div>
                <div>
                    <dt>UPN</dt>
                    <dd>@Model.Identity.UserPrincipalName</dd>
                </div>
                <div>
                    <dt>E-Mail</dt>
                    <dd>@Model.Identity.Email</dd>
                </div>
                <div>
                    <dt>Abteilung</dt>
                    <dd>@Model.Identity.Department</dd>
                </div>
                <div>
                    <dt>Rolle</dt>
                    <dd>@Model.Identity.Title</dd>
                </div>
            </dl>
        </section>

        <form method="post" class="form-grid settings-form">
            <div asp-validation-summary="ModelOnly"></div>
            <fieldset class="settings-group">
                <legend>Darstellung</legend>
                <label class="checkbox-label">
                    <input type="checkbox" asp-for="Input.ReducedMotion" />
                    Reduzierte Bewegung
                </label>
            </fieldset>

            <fieldset class="settings-group">
                <legend>Training</legend>
                <label>
                    Bevorzugter Modus
                    <select asp-for="Input.PreferredMode">
                        @foreach (var mode in Enum.GetValues<TrainingMode>())
                        {
                            <option value="@mode" selected="@(mode == Model.Input.PreferredMode)">@DisplayNames.For(mode)</option>
                        }
                    </select>
                </label>
                <label class="checkbox-label">
                    <input type="checkbox" asp-for="Input.GhostSharingEnabled" />
                    Bestleistungen als Rivalen-Geist freigeben
                </label>
            </fieldset>

            <fieldset class="settings-group">
                <legend>Arena</legend>
                <label class="checkbox-label">
                    <input type="checkbox" asp-for="Input.ShowLiveWpm" />
                    Live-WPM im Rennen anzeigen
                </label>
                <label class="checkbox-label">
                    <input type="checkbox" asp-for="Input.ShowLiveRankChanges" />
                    Rangänderungen ansagen
                </label>
                <label class="checkbox-label">
                    <input type="checkbox" asp-for="Input.SoundEnabled" />
                    Sounds nach Interaktion aktivieren
                </label>
                <label>
                    Lautstärke
                    <input asp-for="Input.SoundVolumePercent" type="range" min="0" max="100" step="5" />
                    <span asp-validation-for="Input.SoundVolumePercent"></span>
                </label>
                <label class="checkbox-label">
                    <input type="checkbox" asp-for="Input.ReactionsEnabled" />
                    Positive Reaktionen in der Arena anzeigen
                </label>
            </fieldset>

            <fieldset class="settings-group">
                <legend>Profil und Privatsphäre</legend>
                <label>
                    Motto
                    <input asp-for="Input.Motto" maxlength="120" />
                </label>
                <label class="checkbox-label">
                    <input type="checkbox" asp-for="Input.LeaderboardVisible" />
                    In Ranglisten sichtbar
                </label>
            </fieldset>

            <div class="form-actions">
                <button type="submit">Speichern</button>
            </div>
        </form>
    </div>
</section>
