@page "/profil/erfolge"
@using System.Globalization
@model KeyWars.Pages.Profil.ErfolgeModel
@{
    ViewData["Title"] = "Erfolge";
    var culture = CultureInfo.GetCultureInfo("de-DE");
}

<section class="page-header">
    <div>
        <span class="eyebrow">Badge-Regal</span>
        <h1>Erfolge</h1>
        <p class="lead">Erfolge würdigen Lernleistung, ohne Shop, Währung oder künstliche Knappheit.</p>
    </div>
    <div class="page-actions">
        <a class="button" asp-page="/Spielen/Index">Nächste Runde</a>
        <a class="button secondary" asp-page="/Profil/Ziele">Ziele öffnen</a>
    </div>
</section>

<section class="achievement-shelf">
@if (Model.UnlockedCount == 0)
{
    <div class="empty-state illustrated-empty">
        <img src="~/vendor/keywars-assets/illustrations/motivator-achievements.svg" alt="" width="280" height="210" loading="lazy" />
        <div>
            <h3>Noch keine Erfolge freigeschaltet</h3>
            <p>Schließe eine gültige Runde ab, halte deine Genauigkeit hoch oder starte ein Arena-Rennen.</p>
            <div class="card-actions">
                <a class="button" asp-page="/Spielen/Index">Runde starten</a>
                <a class="button secondary" asp-page="/Arena/Index">Arena öffnen</a>
            </div>
        </div>
    </div>
}
@foreach (var achievement in Model.Achievements)
{
    var rarity = RarityFor(achievement.Key);
    <article class="card achievement-card rarity-@rarity accent-@achievement.Accent @(achievement.Unlocked ? "is-unlocked" : "is-locked")">
        <div class="achievement-medal">@UiIcons.Svg(achievement.VisualKey, "kw-icon")<span>@MedalFor(achievement.Key)</span></div>
        <div>
            <span class="meta-badge">@achievement.Category · @RarityLabel(rarity)</span>
            <h2>@achievement.Title</h2>
        </div>
        <p>@achievement.Description</p>
        @if (achievement.UnlockedAt is { } unlockedAt)
        {
            <p class="muted">Freigeschaltet am @unlockedAt.LocalDateTime.ToString("g", culture)</p>
        }
        else
        {
            <p class="muted locked-line">@UiIcons.Svg("lock", "kw-icon") Noch gesperrt</p>
        }
    </article>
}
</section>

@functions {
    private static string RarityFor(string key) => key switch
    {
        "speed-100" or "streak-30" or "training-100-attempts" => "epic",
        "speed-80" or "streak-14" or "arena-10" or "precision-100" or "training-50-attempts" => "rare",
        _ when key.StartsWith("arena-", StringComparison.Ordinal) || key.StartsWith("mission-", StringComparison.Ordinal) => "rare",
        _ => "common"
    };

    private static string RarityLabel(string rarity) => rarity switch
    {
        "epic" => "Episch",
        "rare" => "Selten",
        _ => "Standard"
    };

    private static string MedalFor(string key) => key switch
    {
        _ when key.StartsWith("speed-", StringComparison.Ordinal) => "WPM",
        _ when key.StartsWith("precision-", StringComparison.Ordinal) || key == "praezise" => "ACC",
        _ when key.StartsWith("arena-", StringComparison.Ordinal) => "ARE",
        _ when key.StartsWith("mission-", StringComparison.Ordinal) => "Q",
        _ when key.StartsWith("streak-", StringComparison.Ordinal) => "STK",
        _ => "KW"
    };

}
