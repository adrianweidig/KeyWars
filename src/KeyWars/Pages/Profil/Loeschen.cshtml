@page "/profil/loeschen"
@model KeyWars.Pages.Profil.LoeschenModel
@{
    ViewData["Title"] = "Profil löschen";
}

<section class="card">
    <h1>Profil löschen</h1>
    <p>Diese Aktion ist dauerhaft und meldet dich ab.</p>
    <ul>
        <li>AD-Kennungen und Profilangaben werden pseudonymisiert.</li>
        <li>Private Texte, Sammlungen, Training, Missionen, Erfolge und Schwächenbeobachtungen werden entfernt oder geleert.</li>
        <li>Historische Gruppen- und Arena-Ergebnisse bleiben nur mit dem gelöschten Profil verknüpft.</li>
        <li>Ein späterer AD-Login erzeugt ein neues KeyWars-Profil.</li>
    </ul>
    <p>Gib zur Bestätigung deinen Kontonamen <strong>@Model.ConfirmationName</strong> ein.</p>
    <form method="post" class="form-grid">
        <div asp-validation-summary="ModelOnly"></div>
        <label>
            Kontoname
            <input asp-for="Input.Confirmation" autocomplete="off" />
            <span asp-validation-for="Input.Confirmation"></span>
        </label>
        <button type="submit" class="warning">Profil löschen und abmelden</button>
    </form>
</section>
