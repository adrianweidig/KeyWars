@page "/profil"
@model KeyWars.Pages.Profil.IndexModel
@{
    ViewData["Title"] = "Profil";
}

<section class="page-header">
    <div>
        <h1>@Model.Profile.DisplayName</h1>
        <p class="lead">@Model.Profile.SamAccountName · @Model.Profile.Department · @Model.Profile.Title</p>
    </div>
    <div class="action-row">
        <a class="button secondary" asp-page="/Profil/Einstellungen">Einstellungen</a>
        <a class="button secondary" asp-page="/Profil/Erfolge">Erfolge</a>
    </div>
</section>

<section class="grid">
    <article class="card">
        <h2>Fortschritt</h2>
        <div class="metric-row">
            <div class="metric"><span>Level</span><strong>@Model.Profile.Level</strong></div>
            <div class="metric"><span>XP</span><strong>@Model.Profile.ExperiencePoints</strong></div>
            <div class="metric"><span>Rating</span><strong>@Model.Profile.ArenaRating</strong></div>
            <div class="metric"><span>Serie</span><strong>@Model.Profile.CurrentStreakDays</strong></div>
        </div>
        <div class="progress" aria-label="Fortschritt bis zum nächsten Level">
            <span style="width:@Model.LevelProgress.ProgressPercent.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)%"></span>
        </div>
        <p class="muted">@Model.LevelProgress.ProgressXp / @(Model.LevelProgress.NextLevelXp - Model.LevelProgress.LevelStartXp) XP in diesem Level · noch @Model.LevelProgress.RemainingXp XP bis Level @(Model.Profile.Level + 1)</p>
    </article>
    <article class="card">
        <h2>Letzte Versuche</h2>
        <table class="table">
            <thead><tr><th>Modus</th><th>WPM</th><th>Genauigkeit</th></tr></thead>
            <tbody>
            @foreach (var attempt in Model.Attempts)
            {
                <tr>
                    <td>@DisplayNames.For(attempt.Mode)</td>
                    <td>@attempt.Wpm.ToString("0.0")</td>
                    <td>@attempt.Accuracy.ToString("0.0") %</td>
                </tr>
            }
            </tbody>
        </table>
    </article>
</section>
