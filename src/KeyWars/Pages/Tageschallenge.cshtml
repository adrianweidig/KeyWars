@page "/tageschallenge"
@model KeyWars.Pages.TageschallengeModel
@{
    ViewData["Title"] = "Tageschallenge";
}

<section class="page-header">
    <div>
        <h1>Tageschallenge</h1>
        <p class="lead">Der erste gültige Versuch des Tages zählt für deine Tageswertung.</p>
    </div>
</section>

<section class="card" data-typing-app data-mode="Text" data-text-id="@Model.Text.Id">
    <h2>@Model.Text.Title</h2>
    <div class="typing-target" data-target></div>
    <label>
        Eingabe
        <textarea class="typing-input" data-input disabled autocapitalize="off" autocomplete="off" spellcheck="false"></textarea>
    </label>
    <button type="button" data-start>Starten</button>
    <div data-result></div>
</section>
